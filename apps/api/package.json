{
  "name": "@digital-self/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "corepack pnpm --filter @digital-self/shared build && corepack pnpm prisma:generate && tsc -p tsconfig.build.json",
    "start": "node --env-file=../../.env dist/main.js",
    "start:dev": "corepack pnpm --filter @digital-self/shared build && corepack pnpm prisma:generate && node --env-file=../../.env ./node_modules/tsx/dist/cli.mjs watch src/main.ts",
    "prisma:generate": "node --env-file=../../.env ./node_modules/prisma/build/index.js generate --schema ../../packages/shared/prisma/schema.prisma",
    "prisma:migrate:dev": "node --env-file=../../.env ./node_modules/prisma/build/index.js migrate dev --schema ../../packages/shared/prisma/schema.prisma",
    "prisma:migrate:deploy": "node --env-file=../../.env ./node_modules/prisma/build/index.js migrate deploy --schema ../../packages/shared/prisma/schema.prisma",
    "prisma:migrate:status": "node --env-file=../../.env ./node_modules/prisma/build/index.js migrate status --schema ../../packages/shared/prisma/schema.prisma"
  },
  "dependencies": {
    "@digital-self/agent": "workspace:*",
    "@digital-self/shared": "workspace:*",
    "@nestjs/common": "^11.1.8",
    "@nestjs/core": "^11.1.8",
    "@nestjs/platform-express": "^11.1.8",
    "@prisma/client": "^6.19.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "jszip": "^3.10.1",
    "mammoth": "^1.12.0",
    "pdf-parse": "^2.4.5",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.2",
    "@types/node": "^24.0.4",
    "@types/pdf-parse": "^1.1.5",
    "prisma": "^6.19.3",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
