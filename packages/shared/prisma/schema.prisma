generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum DailyEntrySource {
  feishu
  web
  import
}

enum MemoryType {
  goal
  ability
  value
  event
  relationship
  recurring_problem
  decision
}

enum MemoryStatus {
  candidate
  confirmed
  rejected
  expired
}

enum LifeDecisionStatus {
  active
  decided
  archived
}

enum DecisionEvidenceType {
  support
  against
  neutral
}

enum AbilityNodeOrigin {
  system
  custom
}

enum CandidateRecordStatus {
  candidate
  confirmed
  rejected
}

enum AbilityEvidenceImpact {
  positive
  negative
  neutral
}

enum MetricType {
  growth
  emotional_drain
  long_term_fit
  communication_pressure
}

enum CitationSourceType {
  daily_entry
  external_link
  imported_file
  feishu_message
  memory
  event
  project
  ability_evidence
  life_decision
  person
  goal
  plan
  milestone
  action
  weekly_review
  evidence_fragment
}

enum AiMessageRole {
  user
  assistant
}

enum AiMessageStatus {
  completed
  citation_warning
}

enum CitationConsumerType {
  ai_message
  proposal
  analysis
}

enum CitationUsePurpose {
  context
  answer_support
  answer_opposition
}

enum ProposalType {
  event
  memory
  person
  relation
  ability_evidence
  plan
  other
}

enum ProposalOrigin {
  manual
  ai
  migration
}

enum EventType {
  work
  study
  emotion
  decision
  project
  relationship
  other
}

enum EvidenceArtifactType {
  daily_entry
  pasted_text
  uploaded_file
  external_snapshot
  feishu_message
}

enum EvidenceRevisionType {
  original
  parsed
}

enum EvidencePrivacyLevel {
  private
  sensitive
  restricted
}

enum EventTimePrecision {
  exact
  day
  month
  year
  approximate
  unknown
}

enum EventRecordStatus {
  confirmed
  disputed
}

enum EventSourceRole {
  primary
  supporting
}

enum ChangeActorType {
  user
  ai
}

enum GraphEntityType {
  event
  memory
  project
  ability
  decision
  person
  goal
  plan
  milestone
  action
}

enum GoalStatus {
  draft
  active
  achieved
  paused
  abandoned
}

enum FuturePlanStatus {
  draft
  active
  completed
  paused
  abandoned
}

enum MilestoneStatus {
  planned
  active
  completed
  missed
}

enum ActionItemStatus {
  todo
  doing
  done
  cancelled
}

enum GraphRelationStatus {
  candidate
  confirmed
  rejected
}

enum ProjectStatus {
  planned
  active
  completed
  archived
}

enum ImportedFileType {
  pdf
  word
  txt
  markdown
}

enum ImportedFileSourceType {
  resume
  history
  other
}

enum ImportedFileParseStatus {
  pending
  succeeded
  failed
}

enum ResumeDocumentSource {
  pasted
  uploaded
}

enum ResumeMaterialSourceType {
  ability_evidence
  project
  resume_document
  daily_entry
  manual
}

enum ResumeMaterialType {
  achievement
  responsibility
  skill
  project_summary
  reflection
  other
}

enum ResumeMaterialStatus {
  candidate
  confirmed
  rejected
}

enum ToolCallStatus {
  queued
  running
  succeeded
  failed
  cancelled
}

model User {
  id                String             @id @default(uuid()) @db.Uuid
  displayName       String?            @map("display_name")
  timezone          String?
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")
  dailyEntries      DailyEntry[]
  memories          Memory[]
  lifeDecisions     LifeDecision[]
  abilityNodes      AbilityNode[]
  abilityEvidences  AbilityEvidence[]
  externalSources   ExternalSource[]
  importedFiles     ImportedFile[]
  resumeDocuments   ResumeDocument[]
  resumeMaterials   ResumeMaterial[]
  projects          Project[]
  weeklyReviews     WeeklyReview[]
  emotionPatterns   EmotionPattern[]
  toolCallLogs      ToolCallLog[]
  reviewItemHistory ReviewItemHistory[]
  events            Event[]
  evidenceArtifacts EvidenceArtifact[]
  eventCandidates   EventCandidate[]
  graphRelations    GraphRelation[]
  people            Person[]
  goals             Goal[]
  futurePlans       FuturePlan[]
  milestones        Milestone[]
  actionItems       ActionItem[]
  aiSettings        AiSettings?
  aiConversations   AiConversation[]
  sourceCitations   SourceCitation[]
  proposals         Proposal[]

  @@map("users")
}

model DailyEntry {
  id               String                 @id @default(uuid()) @db.Uuid
  userId           String                 @map("user_id") @db.Uuid
  source           DailyEntrySource
  rawContent       String                 @map("raw_content") @db.Text
  recordedAt       DateTime?              @map("recorded_at")
  createdAt        DateTime               @default(now()) @map("created_at")
  updatedAt        DateTime               @updatedAt @map("updated_at")
  user             User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  structuredReport StructuredDailyReport?
  metricRatings    MetricRating[]
  events           Event[]

  @@index([userId, createdAt])
  @@index([source, createdAt])
  @@map("daily_entries")
}

model StructuredDailyReport {
  id             String     @id @default(uuid()) @db.Uuid
  dailyEntryId   String     @unique @map("daily_entry_id") @db.Uuid
  facts          Json
  emotions       Json
  workItems      Json       @map("work_items")
  feedback       Json
  growthEvidence Json       @map("growth_evidence")
  drainSources   Json       @map("drain_sources")
  nextActions    Json       @map("next_actions")
  decisionImpact Json       @map("decision_impact")
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")
  dailyEntry     DailyEntry @relation(fields: [dailyEntryId], references: [id], onDelete: Cascade)

  @@map("structured_daily_reports")
}

model Memory {
  id                 String          @id @default(uuid()) @db.Uuid
  userId             String          @map("user_id") @db.Uuid
  memoryType         MemoryType      @map("memory_type")
  content            String          @db.Text
  sourceCitationId   String?         @map("source_citation_id") @db.Uuid
  status             MemoryStatus
  confidence         Float?
  isMomentaryThought Boolean         @default(false) @map("is_momentary_thought")
  expiresAt          DateTime?       @map("expires_at")
  createdAt          DateTime        @default(now()) @map("created_at")
  updatedAt          DateTime        @updatedAt @map("updated_at")
  user               User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  sourceCitation     SourceCitation? @relation(fields: [sourceCitationId], references: [id], onDelete: SetNull)
  versions           MemoryVersion[]
  evidenceSources    MemorySource[]

  @@index([userId, memoryType, status])
  @@index([expiresAt])
  @@map("memories")
}

model MemoryVersion {
  id              String          @id @default(uuid()) @db.Uuid
  memoryId        String          @map("memory_id") @db.Uuid
  previousContent String          @map("previous_content") @db.Text
  newContent      String          @map("new_content") @db.Text
  changeReason    String?         @map("change_reason") @db.Text
  changedBy       ChangeActorType @map("changed_by")
  createdAt       DateTime        @default(now()) @map("created_at")
  memory          Memory          @relation(fields: [memoryId], references: [id], onDelete: Cascade)

  @@index([memoryId, createdAt])
  @@map("memory_versions")
}

model LifeDecision {
  id              String             @id @default(uuid()) @db.Uuid
  userId          String             @map("user_id") @db.Uuid
  title           String
  description     String?            @db.Text
  deadline        DateTime?
  status          LifeDecisionStatus
  finalDecision   String?            @map("final_decision") @db.Text
  createdAt       DateTime           @default(now()) @map("created_at")
  updatedAt       DateTime           @updatedAt @map("updated_at")
  user            User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  paths           DecisionPath[]
  evidenceItems   DecisionEvidence[]
  externalSources ExternalSource[]
  weeklyReviews   WeeklyReview[]

  @@index([userId, status, deadline])
  @@map("life_decisions")
}

model DecisionPath {
  id            String             @id @default(uuid()) @db.Uuid
  decisionId    String             @map("decision_id") @db.Uuid
  title         String
  description   String?            @db.Text
  benefits      Json
  risks         Json
  currentScore  Float?             @map("current_score")
  createdAt     DateTime           @default(now()) @map("created_at")
  updatedAt     DateTime           @updatedAt @map("updated_at")
  decision      LifeDecision       @relation(fields: [decisionId], references: [id], onDelete: Cascade)
  evidenceItems DecisionEvidence[]

  @@index([decisionId, createdAt])
  @@map("decision_paths")
}

model DecisionEvidence {
  id               String               @id @default(uuid()) @db.Uuid
  decisionId       String               @map("decision_id") @db.Uuid
  pathId           String               @map("path_id") @db.Uuid
  evidenceType     DecisionEvidenceType @map("evidence_type")
  content          String               @db.Text
  sourceCitationId String?              @map("source_citation_id") @db.Uuid
  weight           Float?
  createdAt        DateTime             @default(now()) @map("created_at")
  updatedAt        DateTime             @updatedAt @map("updated_at")
  decision         LifeDecision         @relation(fields: [decisionId], references: [id], onDelete: Cascade)
  path             DecisionPath         @relation(fields: [pathId], references: [id], onDelete: Cascade)
  sourceCitation   SourceCitation?      @relation(fields: [sourceCitationId], references: [id], onDelete: SetNull)

  @@index([decisionId, pathId, evidenceType])
  @@map("decision_evidence")
}

model AbilityNode {
  id            String            @id @default(uuid()) @db.Uuid
  userId        String            @map("user_id") @db.Uuid
  parentId      String?           @map("parent_id") @db.Uuid
  name          String
  description   String?           @db.Text
  level         Int               @default(1)
  origin        AbilityNodeOrigin @default(custom)
  createdAt     DateTime          @default(now()) @map("created_at")
  updatedAt     DateTime          @updatedAt @map("updated_at")
  user          User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent        AbilityNode?      @relation("AbilityNodeHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children      AbilityNode[]     @relation("AbilityNodeHierarchy")
  evidenceItems AbilityEvidence[]

  @@unique([userId, parentId, name])
  @@index([userId, parentId])
  @@map("ability_nodes")
}

model AbilityEvidence {
  id                String                   @id @default(uuid()) @db.Uuid
  userId            String                   @map("user_id") @db.Uuid
  abilityNodeId     String                   @map("ability_node_id") @db.Uuid
  sourceCitationId  String?                  @map("source_citation_id") @db.Uuid
  content           String                   @db.Text
  impact            AbilityEvidenceImpact
  difficultyScore   Int                      @map("difficulty_score")
  independenceScore Int                      @map("independence_score")
  impactScore       Int                      @map("impact_score")
  feedbackScore     Int                      @map("feedback_score")
  recurrenceCount   Int                      @default(1) @map("recurrence_count")
  status            CandidateRecordStatus    @default(candidate)
  createdAt         DateTime                 @default(now()) @map("created_at")
  updatedAt         DateTime                 @updatedAt @map("updated_at")
  user              User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  abilityNode       AbilityNode              @relation(fields: [abilityNodeId], references: [id], onDelete: Cascade)
  sourceCitation    SourceCitation?          @relation(fields: [sourceCitationId], references: [id], onDelete: SetNull)
  projects          ProjectAbilityEvidence[]

  @@index([userId, abilityNodeId, status])
  @@map("ability_evidence")
}

model MetricRating {
  id              String     @id @default(uuid()) @db.Uuid
  dailyEntryId    String     @map("daily_entry_id") @db.Uuid
  metricType      MetricType @map("metric_type")
  aiScore         Int?       @map("ai_score")
  userScore       Int?       @map("user_score")
  finalScore      Int?       @map("final_score")
  aiReason        String?    @map("ai_reason") @db.Text
  confirmedByUser Boolean    @default(false) @map("confirmed_by_user")
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")
  dailyEntry      DailyEntry @relation(fields: [dailyEntryId], references: [id], onDelete: Cascade)

  @@unique([dailyEntryId, metricType])
  @@map("metric_ratings")
}

model SourceCitation {
  id                    String             @id @default(uuid()) @db.Uuid
  userId                String?            @map("user_id") @db.Uuid
  sourceType            CitationSourceType @map("source_type")
  sourceId              String             @map("source_id")
  sourceVersionId       String?            @map("source_version_id")
  contentHash           String?            @map("content_hash")
  title                 String?
  url                   String?
  excerpt               String?            @db.Text
  locator               String?
  metadata              Json?
  createdAt             DateTime           @default(now()) @map("created_at")
  user                  User?              @relation(fields: [userId], references: [id], onDelete: Cascade)
  memories              Memory[]
  eventItems            Event[]
  decisionEvidenceItems DecisionEvidence[]
  abilityEvidenceItems  AbilityEvidence[]
  uses                  CitationUse[]

  @@index([sourceType, sourceId])
  @@index([userId, sourceType, sourceId])
  @@index([contentHash])
  @@map("source_citations")
}

model AiSettings {
  id                          String    @id @default(uuid()) @db.Uuid
  userId                      String    @unique @map("user_id") @db.Uuid
  baseUrl                     String    @map("base_url")
  fastModel                   String    @map("fast_model")
  analysisModel               String    @map("analysis_model")
  credentialRef               String?   @map("credential_ref")
  enabled                     Boolean   @default(false)
  externalProcessingConsentAt DateTime? @map("external_processing_consent_at")
  createdAt                   DateTime  @default(now()) @map("created_at")
  updatedAt                   DateTime  @updatedAt @map("updated_at")
  user                        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("ai_settings")
}

model AiConversation {
  id        String      @id @default(uuid()) @db.Uuid
  userId    String      @map("user_id") @db.Uuid
  title     String
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  AiMessage[]

  @@index([userId, updatedAt])
  @@map("ai_conversations")
}

model AiMessage {
  id             String          @id @default(uuid()) @db.Uuid
  conversationId String          @map("conversation_id") @db.Uuid
  role           AiMessageRole
  content        String          @db.Text
  model          String?
  status         AiMessageStatus @default(completed)
  errorMessage   String?         @map("error_message") @db.Text
  inputTokens    Int?            @map("input_tokens")
  outputTokens   Int?            @map("output_tokens")
  totalTokens    Int?            @map("total_tokens")
  latencyMs      Int?            @map("latency_ms")
  sourceCount    Int?            @map("source_count")
  sentCharacterCount Int?        @map("sent_character_count")
  citationCheckPassed Boolean?    @map("citation_check_passed")
  createdAt      DateTime        @default(now()) @map("created_at")
  conversation   AiConversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@map("ai_messages")
}

model CitationUse {
  id           String               @id @default(uuid()) @db.Uuid
  citationId   String               @map("citation_id") @db.Uuid
  consumerType CitationConsumerType @map("consumer_type")
  consumerId   String               @map("consumer_id") @db.Uuid
  purpose      CitationUsePurpose
  createdAt    DateTime             @default(now()) @map("created_at")
  citation     SourceCitation       @relation(fields: [citationId], references: [id], onDelete: Cascade)

  @@unique([citationId, consumerType, consumerId, purpose])
  @@index([consumerType, consumerId])
  @@map("citation_uses")
}

model Embedding {
  id             String                 @id @default(uuid()) @db.Uuid
  sourceType     CitationSourceType     @map("source_type")
  sourceId       String                 @map("source_id")
  chunkIndex     Int                    @default(0) @map("chunk_index")
  content        String                 @db.Text
  embeddingModel String                 @map("embedding_model")
  dimensions     Int?
  contentHash    String                 @map("content_hash")
  vector         Unsupported("vector")?
  createdAt      DateTime               @default(now()) @map("created_at")

  @@unique([sourceType, sourceId, chunkIndex])
  @@index([contentHash])
  @@map("embeddings")
}

model Project {
  id              String                   @id @default(uuid()) @db.Uuid
  userId          String                   @map("user_id") @db.Uuid
  name            String
  description     String?                  @db.Text
  role            String?
  startDate       DateTime?                @map("start_date")
  endDate         DateTime?                @map("end_date")
  status          ProjectStatus
  outcomes        Json
  resumeSummary   String?                  @map("resume_summary") @db.Text
  createdAt       DateTime                 @default(now()) @map("created_at")
  updatedAt       DateTime                 @updatedAt @map("updated_at")
  user            User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  abilityEvidence ProjectAbilityEvidence[]

  @@index([userId, status])
  @@map("projects")
}

model ProjectAbilityEvidence {
  projectId         String          @map("project_id") @db.Uuid
  abilityEvidenceId String          @map("ability_evidence_id") @db.Uuid
  linkedAt          DateTime        @default(now()) @map("linked_at")
  project           Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  abilityEvidence   AbilityEvidence @relation(fields: [abilityEvidenceId], references: [id], onDelete: Cascade)

  @@id([projectId, abilityEvidenceId])
  @@map("project_ability_evidence")
}

model ImportedFile {
  id              String                  @id @default(uuid()) @db.Uuid
  userId          String                  @map("user_id") @db.Uuid
  fileName        String                  @map("file_name")
  fileType        ImportedFileType        @map("file_type")
  sourceType      ImportedFileSourceType  @map("source_type")
  mimeType        String?                 @map("mime_type")
  fileSizeBytes   Int?                    @map("file_size_bytes")
  contentHash     String?                 @map("content_hash")
  storagePath     String?                 @map("storage_path")
  parsedText      String?                 @map("parsed_text") @db.Text
  parseStatus     ImportedFileParseStatus @default(pending) @map("parse_status")
  parseError      String?                 @map("parse_error") @db.Text
  createdAt       DateTime                @default(now()) @map("created_at")
  updatedAt       DateTime                @updatedAt @map("updated_at")
  user            User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  resumeDocuments ResumeDocument[]

  @@index([userId, sourceType, createdAt])
  @@index([contentHash])
  @@map("imported_files")
}

model EvidenceArtifact {
  id           String               @id @default(uuid()) @db.Uuid
  userId       String               @map("user_id") @db.Uuid
  artifactType EvidenceArtifactType @map("artifact_type")
  title        String?
  originalUri  String?              @map("original_uri")
  mimeType     String?              @map("mime_type")
  privacyLevel EvidencePrivacyLevel @default(private) @map("privacy_level")
  capturedAt   DateTime?            @map("captured_at")
  createdAt    DateTime             @default(now()) @map("created_at")
  user         User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  revisions    EvidenceRevision[]

  @@index([userId, capturedAt])
  @@index([userId, artifactType, createdAt])
  @@map("evidence_artifacts")
}

model EvidenceRevision {
  id             String               @id @default(uuid()) @db.Uuid
  artifactId     String               @map("artifact_id") @db.Uuid
  revisionNumber Int                  @map("revision_number")
  revisionType   EvidenceRevisionType @map("revision_type")
  contentHash    String               @map("content_hash")
  content        String?              @db.Text
  storagePath    String?              @map("storage_path")
  parserVersion  String?              @map("parser_version")
  createdAt      DateTime             @default(now()) @map("created_at")
  artifact       EvidenceArtifact     @relation(fields: [artifactId], references: [id], onDelete: Cascade)
  fragments      EvidenceFragment[]

  @@unique([artifactId, revisionNumber])
  @@index([contentHash])
  @@map("evidence_revisions")
}

model EvidenceFragment {
  id                String             @id @default(uuid()) @db.Uuid
  revisionId        String             @map("revision_id") @db.Uuid
  fragmentIndex     Int                @map("fragment_index")
  content           String             @db.Text
  startOffset       Int?               @map("start_offset")
  endOffset         Int?               @map("end_offset")
  locator           Json?
  createdAt         DateTime           @default(now()) @map("created_at")
  revision          EvidenceRevision   @relation(fields: [revisionId], references: [id], onDelete: Cascade)
  eventCandidates   EventCandidate[]
  eventSources      EventSource[]
  memorySources     MemorySource[]
  graphRelations    GraphRelation[]
  eventParticipants EventParticipant[]
  proposals          Proposal[]

  @@unique([revisionId, fragmentIndex])
  @@map("evidence_fragments")
}

model EventCandidate {
  id                 String                @id @default(uuid()) @db.Uuid
  userId             String                @map("user_id") @db.Uuid
  evidenceFragmentId String                @map("evidence_fragment_id") @db.Uuid
  title              String
  description        String?               @db.Text
  eventType          EventType             @map("event_type")
  occurredAt         DateTime              @map("occurred_at")
  timePrecision      EventTimePrecision    @default(unknown) @map("time_precision")
  status             CandidateRecordStatus @default(candidate)
  confidence         Float?
  reviewedAt         DateTime?             @map("reviewed_at")
  confirmedEventId   String?               @unique @map("confirmed_event_id") @db.Uuid
  createdAt          DateTime              @default(now()) @map("created_at")
  updatedAt          DateTime              @updatedAt @map("updated_at")
  user               User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  evidenceFragment   EvidenceFragment      @relation(fields: [evidenceFragmentId], references: [id], onDelete: Restrict)
  confirmedEvent     Event?                @relation(fields: [confirmedEventId], references: [id], onDelete: SetNull)

  @@index([userId, status, createdAt])
  @@index([evidenceFragmentId])
  @@map("event_candidates")
}

model Proposal {
  id                 String                @id @default(uuid()) @db.Uuid
  userId             String                @map("user_id") @db.Uuid
  proposalType       ProposalType          @map("proposal_type")
  status             CandidateRecordStatus @default(candidate)
  title              String
  summary            String?               @db.Text
  payload            Json
  evidenceFragmentId String?               @map("evidence_fragment_id") @db.Uuid
  confidence         Float?
  origin             ProposalOrigin        @default(manual)
  reviewedAt         DateTime?             @map("reviewed_at")
  appliedEntityType  String?               @map("applied_entity_type")
  appliedEntityId    String?               @map("applied_entity_id") @db.Uuid
  createdAt          DateTime              @default(now()) @map("created_at")
  updatedAt          DateTime              @updatedAt @map("updated_at")
  user               User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  evidenceFragment   EvidenceFragment?     @relation(fields: [evidenceFragmentId], references: [id], onDelete: Restrict)
  reviews            ProposalReview[]

  @@index([userId, status, createdAt])
  @@index([userId, proposalType, status])
  @@index([evidenceFragmentId])
  @@index([appliedEntityType, appliedEntityId])
  @@map("proposals")
}

model ProposalReview {
  id           String                @id @default(uuid()) @db.Uuid
  proposalId   String                @map("proposal_id") @db.Uuid
  fromStatus   CandidateRecordStatus @map("from_status")
  toStatus     CandidateRecordStatus @map("to_status")
  actor        ChangeActorType       @default(user)
  snapshot     Json
  note         String?               @db.Text
  createdAt    DateTime              @default(now()) @map("created_at")
  proposal     Proposal              @relation(fields: [proposalId], references: [id], onDelete: Cascade)

  @@index([proposalId, createdAt])
  @@map("proposal_reviews")
}

model ResumeDocument {
  id             String               @id @default(uuid()) @db.Uuid
  userId         String               @map("user_id") @db.Uuid
  importedFileId String?              @map("imported_file_id") @db.Uuid
  source         ResumeDocumentSource
  title          String?
  content        String               @db.Text
  isPrimary      Boolean              @default(false) @map("is_primary")
  createdAt      DateTime             @default(now()) @map("created_at")
  updatedAt      DateTime             @updatedAt @map("updated_at")
  user           User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  importedFile   ImportedFile?        @relation(fields: [importedFileId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([userId, updatedAt])
  @@index([importedFileId])
  @@map("resume_documents")
}

model ResumeMaterial {
  id              String                   @id @default(uuid()) @db.Uuid
  userId          String                   @map("user_id") @db.Uuid
  sourceType      ResumeMaterialSourceType @map("source_type")
  sourceId        String?                  @map("source_id") @db.Uuid
  materialType    ResumeMaterialType       @map("material_type")
  content         String                   @db.Text
  suggestedBullet String?                  @map("suggested_bullet") @db.Text
  status          ResumeMaterialStatus     @default(candidate)
  confidence      Float?
  createdAt       DateTime                 @default(now()) @map("created_at")
  updatedAt       DateTime                 @updatedAt @map("updated_at")
  user            User                     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status, createdAt])
  @@index([userId, sourceType, createdAt])
  @@index([userId, sourceType, sourceId])
  @@map("resume_materials")
}

model ExternalSource {
  id                 String        @id @default(uuid()) @db.Uuid
  userId             String        @map("user_id") @db.Uuid
  lifeDecisionId     String?       @map("life_decision_id") @db.Uuid
  title              String
  sourceSite         String        @map("source_site")
  url                String
  publishedAt        DateTime?     @map("published_at")
  fetchedAt          DateTime?     @map("fetched_at")
  summary            String?       @db.Text
  relationToDecision String?       @map("relation_to_decision") @db.Text
  createdAt          DateTime      @default(now()) @map("created_at")
  updatedAt          DateTime      @updatedAt @map("updated_at")
  user               User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  lifeDecision       LifeDecision? @relation(fields: [lifeDecisionId], references: [id], onDelete: SetNull)

  @@index([userId, fetchedAt])
  @@index([lifeDecisionId, createdAt])
  @@map("external_sources")
}

model ToolCallLog {
  id            String         @id @default(uuid()) @db.Uuid
  userId        String?        @map("user_id") @db.Uuid
  agentName     String         @map("agent_name")
  toolName      String         @map("tool_name")
  inputSummary  String?        @map("input_summary") @db.Text
  outputSummary String?        @map("output_summary") @db.Text
  status        ToolCallStatus
  latencyMs     Int?           @map("latency_ms")
  service       String?        @db.Text
  model         String?
  sourceCount   Int?           @map("source_count")
  sentCharacterCount Int?      @map("sent_character_count")
  inputTokens   Int?           @map("input_tokens")
  outputTokens  Int?           @map("output_tokens")
  totalTokens   Int?           @map("total_tokens")
  requestId     String?        @map("request_id")
  errorMessage  String?        @map("error_message") @db.Text
  createdAt     DateTime       @default(now()) @map("created_at")
  user          User?          @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([agentName, status, createdAt])
  @@index([requestId])
  @@map("tool_call_logs")
}

model ReviewItemHistory {
