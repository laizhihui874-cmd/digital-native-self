  userId     String                @map("user_id") @db.Uuid
  kind       String
  itemId     String                @map("item_id") @db.Uuid
  fromStatus CandidateRecordStatus @map("from_status")
  toStatus   CandidateRecordStatus @map("to_status")
  snapshot   Json
  note       String?               @db.Text
  createdAt  DateTime              @default(now()) @map("created_at")
  user       User                  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, kind, itemId, createdAt])
  @@map("review_item_history")
}

model WeeklyReview {
  id                   String          @id @default(uuid()) @db.Uuid
  userId               String          @map("user_id") @db.Uuid
  lifeDecisionId       String?         @map("life_decision_id") @db.Uuid
  periodStart          DateTime        @map("period_start")
  periodEnd            DateTime        @map("period_end")
  progressSummary      String?         @map("progress_summary") @db.Text
  abilityChanges       Json            @map("ability_changes")
  emotionPatterns      Json            @map("emotion_patterns")
  goalDrift            String?         @map("goal_drift") @db.Text
  nextWeekSuggestions  Json            @map("next_week_suggestions")
  lifePossibilityNotes String?         @map("life_possibility_notes") @db.Text
  createdAt            DateTime        @default(now()) @map("created_at")
  updatedAt            DateTime        @updatedAt @map("updated_at")
  user                 User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  lifeDecision         LifeDecision?   @relation(fields: [lifeDecisionId], references: [id], onDelete: SetNull)
  emotionPattern       EmotionPattern?

  @@unique([userId, periodStart, periodEnd])
  @@index([lifeDecisionId, periodStart])
  @@map("weekly_reviews")
}

model EmotionPattern {
  id               String        @id @default(uuid()) @db.Uuid
  userId           String        @map("user_id") @db.Uuid
  weeklyReviewId   String?       @unique @map("weekly_review_id") @db.Uuid
  periodStart      DateTime      @map("period_start")
  periodEnd        DateTime      @map("period_end")
  dominantEmotions Json          @map("dominant_emotions")
  triggers         Json
  patterns         Json
  decisionRisk     String?       @map("decision_risk") @db.Text
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")
  user             User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  weeklyReview     WeeklyReview? @relation(fields: [weeklyReviewId], references: [id], onDelete: SetNull)

  @@unique([userId, periodStart, periodEnd])
  @@index([weeklyReviewId])
  @@map("emotion_patterns")
}

model Event {
  id                      String             @id @default(uuid()) @db.Uuid
  userId                  String             @map("user_id") @db.Uuid
  dailyEntryId            String?            @map("daily_entry_id") @db.Uuid
  title                   String
  description             String?            @db.Text
  eventType               EventType          @map("event_type")
  occurredAt              DateTime           @map("occurred_at")
  endedAt                 DateTime?          @map("ended_at")
  timePrecision           EventTimePrecision @default(unknown) @map("time_precision")
  recordStatus            EventRecordStatus  @default(confirmed) @map("record_status")
  primarySourceCitationId String?            @map("primary_source_citation_id") @db.Uuid
  createdAt               DateTime           @default(now()) @map("created_at")
  updatedAt               DateTime           @updatedAt @map("updated_at")
  user                    User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  dailyEntry              DailyEntry?        @relation(fields: [dailyEntryId], references: [id], onDelete: SetNull)
  primarySourceCitation   SourceCitation?    @relation(fields: [primarySourceCitationId], references: [id], onDelete: SetNull)
  revisions               EventRevision[]
  sources                 EventSource[]
  candidate               EventCandidate?
  participants            EventParticipant[]

  @@index([userId, occurredAt])
  @@index([dailyEntryId, createdAt])
  @@map("events")
}

model EventRevision {
  id             String             @id @default(uuid()) @db.Uuid
  eventId        String             @map("event_id") @db.Uuid
  revisionNumber Int                @map("revision_number")
  title          String
  description    String?            @db.Text
  eventType      EventType          @map("event_type")
  occurredAt     DateTime           @map("occurred_at")
  endedAt        DateTime?          @map("ended_at")
  timePrecision  EventTimePrecision @map("time_precision")
  recordStatus   EventRecordStatus  @map("record_status")
  changeReason   String?            @map("change_reason") @db.Text
  changedBy      ChangeActorType    @map("changed_by")
  createdAt      DateTime           @default(now()) @map("created_at")
  event          Event              @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([eventId, revisionNumber])
  @@index([eventId, createdAt])
  @@map("event_revisions")
}

model EventSource {
  eventId            String           @map("event_id") @db.Uuid
  evidenceFragmentId String           @map("evidence_fragment_id") @db.Uuid
  role               EventSourceRole  @default(supporting)
  createdAt          DateTime         @default(now()) @map("created_at")
  event              Event            @relation(fields: [eventId], references: [id], onDelete: Cascade)
  evidenceFragment   EvidenceFragment @relation(fields: [evidenceFragmentId], references: [id], onDelete: Restrict)

  @@id([eventId, evidenceFragmentId])
  @@index([evidenceFragmentId])
  @@map("event_sources")
}

model MemorySource {
  memoryId           String           @map("memory_id") @db.Uuid
  evidenceFragmentId String           @map("evidence_fragment_id") @db.Uuid
  role               EventSourceRole  @default(supporting)
  createdAt          DateTime         @default(now()) @map("created_at")
  memory             Memory           @relation(fields: [memoryId], references: [id], onDelete: Cascade)
  evidenceFragment   EvidenceFragment @relation(fields: [evidenceFragmentId], references: [id], onDelete: Restrict)

  @@id([memoryId, evidenceFragmentId])
  @@index([evidenceFragmentId])
  @@map("memory_sources")
}

model GraphRelation {
  id                 String              @id @default(uuid()) @db.Uuid
  userId             String              @map("user_id") @db.Uuid
  sourceType         GraphEntityType     @map("source_type")
  sourceId           String              @map("source_id") @db.Uuid
  targetType         GraphEntityType     @map("target_type")
  targetId           String              @map("target_id") @db.Uuid
  relationType       String              @map("relation_type")
  label              String
  status             GraphRelationStatus @default(confirmed)
  validFrom          DateTime?           @map("valid_from")
  validTo            DateTime?           @map("valid_to")
  evidenceFragmentId String?             @map("evidence_fragment_id") @db.Uuid
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")
  user               User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  evidenceFragment   EvidenceFragment?   @relation(fields: [evidenceFragmentId], references: [id], onDelete: SetNull)

  @@index([userId, status, createdAt])
  @@index([sourceType, sourceId])
  @@index([targetType, targetId])
  @@map("graph_relations")
}

model Person {
  id                  String             @id @default(uuid()) @db.Uuid
  userId              String             @map("user_id") @db.Uuid
  name                String
  relationship        String?
  description         String?            @db.Text
  firstMetAt          DateTime?          @map("first_met_at")
  createdAt           DateTime           @default(now()) @map("created_at")
  updatedAt           DateTime           @updatedAt @map("updated_at")
  user                User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  eventParticipations EventParticipant[]

  @@index([userId, name])
  @@map("people")
}

model EventParticipant {
  id                 String            @id @default(uuid()) @db.Uuid
  eventId            String            @map("event_id") @db.Uuid
  personId           String            @map("person_id") @db.Uuid
  role               String?
  description        String?           @db.Text
  evidenceFragmentId String?           @map("evidence_fragment_id") @db.Uuid
  validFrom          DateTime?         @map("valid_from")
  validTo            DateTime?         @map("valid_to")
  createdAt          DateTime          @default(now()) @map("created_at")
  updatedAt          DateTime          @updatedAt @map("updated_at")
  event              Event             @relation(fields: [eventId], references: [id], onDelete: Cascade)
  person             Person            @relation(fields: [personId], references: [id], onDelete: Cascade)
  evidenceFragment   EvidenceFragment? @relation(fields: [evidenceFragmentId], references: [id], onDelete: SetNull)

  @@index([eventId, createdAt])
  @@index([personId, createdAt])
  @@index([evidenceFragmentId])
  @@map("event_participants")
}

model Goal {
  id              String       @id @default(uuid()) @db.Uuid
  userId          String       @map("user_id") @db.Uuid
  title           String
  description     String?      @db.Text
  area            String?
  successCriteria String?      @map("success_criteria") @db.Text
  status          GoalStatus   @default(active)
  priority        Int          @default(3)
  targetDate      DateTime?    @map("target_date")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  plans           FuturePlan[]

  @@index([userId, status, targetDate])
  @@map("goals")
}

model FuturePlan {
  id          String           @id @default(uuid()) @db.Uuid
  userId      String           @map("user_id") @db.Uuid
  goalId      String           @map("goal_id") @db.Uuid
  title       String
  description String?          @db.Text
  status      FuturePlanStatus @default(active)
  startDate   DateTime?        @map("start_date")
  endDate     DateTime?        @map("end_date")
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  goal        Goal             @relation(fields: [goalId], references: [id], onDelete: Cascade)
  milestones  Milestone[]
  actionItems ActionItem[]

  @@index([userId, status, endDate])
  @@index([goalId, createdAt])
  @@map("future_plans")
}

model Milestone {
  id          String          @id @default(uuid()) @db.Uuid
  userId      String          @map("user_id") @db.Uuid
  planId      String          @map("plan_id") @db.Uuid
  title       String
  description String?         @db.Text
  status      MilestoneStatus @default(planned)
  dueAt       DateTime?       @map("due_at")
  completedAt DateTime?       @map("completed_at")
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan        FuturePlan      @relation(fields: [planId], references: [id], onDelete: Cascade)
  actionItems ActionItem[]

  @@index([userId, status, dueAt])
  @@index([planId, dueAt])
  @@map("milestones")
}

model ActionItem {
  id          String           @id @default(uuid()) @db.Uuid
  userId      String           @map("user_id") @db.Uuid
  planId      String           @map("plan_id") @db.Uuid
  milestoneId String?          @map("milestone_id") @db.Uuid
  title       String
  description String?          @db.Text
  status      ActionItemStatus @default(todo)
  dueAt       DateTime?        @map("due_at")
  completedAt DateTime?        @map("completed_at")
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan        FuturePlan       @relation(fields: [planId], references: [id], onDelete: Cascade)
  milestone   Milestone?       @relation(fields: [milestoneId], references: [id], onDelete: SetNull)

  @@index([userId, status, dueAt])
  @@index([planId, createdAt])
  @@index([milestoneId, createdAt])
  @@map("action_items")
}
