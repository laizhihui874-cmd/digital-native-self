{
  "name": "digital-self-mvp",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.12.1",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "dev:web": "corepack pnpm --filter digital-self-web dev",
    "dev:api": "corepack pnpm --filter @digital-self/api start:dev",
    "build": "corepack pnpm --filter @digital-self/shared build && corepack pnpm --filter @digital-self/agent build && corepack pnpm --filter @digital-self/mcp build && corepack pnpm --filter @digital-self/api build && corepack pnpm --filter digital-self-web build",
    "build:web": "corepack pnpm --filter digital-self-web build",
    "build:api": "corepack pnpm --filter @digital-self/api build",
    "build:shared": "corepack pnpm --filter @digital-self/shared build",
    "build:agent": "corepack pnpm --filter @digital-self/agent build",
    "build:mcp": "corepack pnpm --filter @digital-self/mcp build",
    "verify:base": "corepack pnpm build:shared && corepack pnpm build:agent && corepack pnpm build:api && corepack pnpm --filter @digital-self/agent typecheck",
    "verify:agent-deterministic": "corepack pnpm build:agent && node ./scripts/verify-agent-deterministic.mjs",
    "verify:ability-evidence": "node ./scripts/run-isolated-api-verification.mjs ./scripts/verify-ability-evidence-api.mjs",
    "verify:ability-nodes": "node ./scripts/run-isolated-api-verification.mjs ./scripts/verify-ability-nodes-api.mjs",
    "verify:daily-entry": "node ./scripts/run-isolated-api-verification.mjs ./scripts/verify-daily-entry-api.mjs",
    "verify:evidence-event-archive": "node ./scripts/run-isolated-api-verification.mjs ./scripts/verify-evidence-event-archive.mjs",
    "verify:archive-ui": "node ./scripts/run-isolated-api-verification.mjs ./scripts/verify-archive-ui.mjs",
    "verify:data-control": "node ./scripts/run-isolated-api-verification.mjs ./scripts/verify-data-control.mjs",
    "verify:archive-restore": "node ./scripts/run-isolated-api-verification.mjs ./scripts/verify-archive-restore.mjs",
    "verify:data-control-ui": "node ./scripts/run-isolated-api-verification.mjs ./scripts/verify-data-control-ui.mjs",
    "verify:daily-entry-structured-report-generate": "node ./scripts/run-isolated-api-verification.mjs ./scripts/verify-daily-entry-structured-report-generate-api.mjs",
    "verify:daily-entry-structured-draft": "node ./scripts/run-isolated-api-verification.mjs ./scripts/verify-daily-entry-structured-draft-api.mjs",
    "verify:metric-ratings": "node ./scripts/run-isolated-api-verification.mjs ./scripts/verify-metric-ratings-api.mjs",
    "verify:structured-daily-report": "node ./scripts/run-isolated-api-verification.mjs ./scripts/verify-structured-daily-report-api.mjs",
    "verify:memory-candidates": "node ./scripts/run-isolated-api-verification.mjs ./scripts/verify-memory-candidates-api.mjs",
    "verify:memory-review": "node ./scripts/run-isolated-api-verification.mjs ./scripts/verify-memory-review-api.mjs",
    "verify:memory-rag": "node ./scripts/run-isolated-api-verification.mjs ./scripts/verify-memory-rag-api.mjs",
    "verify:archive-search": "node ./scripts/run-isolated-api-verification.mjs ./scripts/verify-archive-search-api.mjs",
    "verify:ai-assistant": "node ./scripts/run-isolated-api-verification.mjs ./scripts/verify-ai-assistant-api.mjs",
    "verify:ai-assistant-ui": "node ./scripts/run-isolated-api-verification.mjs ./scripts/verify-ai-assistant-ui.mjs",
    "verify:review-items": "node ./scripts/run-isolated-api-verification.mjs ./scripts/verify-review-items-api.mjs",
    "verify:review-items-ui": "node ./scripts/run-isolated-api-verification.mjs ./scripts/verify-review-items-ui.mjs",
    "verify:life-decisions": "node ./scripts/run-isolated-api-verification.mjs ./scripts/verify-life-decisions-api.mjs",
    "verify:external-sources": "node ./scripts/run-isolated-api-verification.mjs ./scripts/verify-external-sources-api.mjs",
    "verify:external-source-search": "node ./scripts/run-isolated-api-verification.mjs ./scripts/verify-external-source-search-api.mjs",
    "verify:external-source-impact-draft": "node ./scripts/run-isolated-api-verification.mjs ./scripts/verify-external-source-impact-draft-api.mjs",
    "verify:decision-evidence": "node ./scripts/run-isolated-api-verification.mjs ./scripts/verify-decision-evidence-api.mjs",
    "verify:weekly-reviews": "node ./scripts/run-isolated-api-verification.mjs ./scripts/verify-weekly-reviews-api.mjs",
    "verify:projects": "node ./scripts/run-isolated-api-verification.mjs ./scripts/verify-projects-api.mjs",
    "verify:life-graph": "corepack pnpm build:api && node ./scripts/verify-life-graph-builder.mjs",
    "verify:graph-relations": "node ./scripts/run-isolated-api-verification.mjs ./scripts/verify-graph-relations.mjs",
    "verify:graph-relations-ui": "node ./scripts/run-isolated-api-verification.mjs ./scripts/verify-graph-relations-ui.mjs",
    "verify:people-graph": "node ./scripts/run-isolated-api-verification.mjs ./scripts/verify-people-graph.mjs",
    "verify:people-ui": "node ./scripts/run-isolated-api-verification.mjs ./scripts/verify-people-ui.mjs",
    "verify:event-participants": "node ./scripts/run-isolated-api-verification.mjs ./scripts/verify-event-participants.mjs",
    "verify:event-participants-ui": "node ./scripts/run-isolated-api-verification.mjs ./scripts/verify-event-participants-ui.mjs",
    "verify:planning-graph": "node ./scripts/run-isolated-api-verification.mjs ./scripts/verify-planning-graph.mjs",
    "verify:planning-ui": "node ./scripts/run-isolated-api-verification.mjs ./scripts/verify-planning-ui.mjs",
    "verify:resume-documents": "node ./scripts/run-isolated-api-verification.mjs ./scripts/verify-resume-documents-api.mjs",
    "verify:resume-materials": "node ./scripts/run-isolated-api-verification.mjs ./scripts/verify-resume-materials-api.mjs",
    "verify:resume-gap-analysis": "node ./scripts/run-isolated-api-verification.mjs ./scripts/verify-resume-gap-analysis-api.mjs",
    "verify:project-packaging-suggestions": "node ./scripts/run-isolated-api-verification.mjs ./scripts/verify-project-packaging-suggestions-api.mjs",
    "verify:security-baseline": "node ./scripts/run-isolated-api-verification.mjs ./scripts/verify-security-baseline.mjs",
    "verify:web-ui-smoke": "node ./scripts/run-isolated-api-verification.mjs ./scripts/verify-web-ui-smoke.mjs",
    "verify:home-states": "node ./scripts/run-isolated-api-verification.mjs ./scripts/verify-home-states.mjs",
    "verify:test-database-safety": "node ./scripts/verify-test-database-safety.mjs",
    "verify:api-host": "node ./scripts/verify-api-host.mjs",
    "verify:app-runtime": "node ./scripts/verify-app-runtime.mjs",
    "verify:ci": "corepack pnpm verify:test-database-safety && corepack pnpm verify:base && corepack pnpm verify:api-host && corepack pnpm build:mcp && corepack pnpm --filter @digital-self/mcp typecheck && corepack pnpm verify:agent-deterministic && corepack pnpm verify:life-graph && corepack pnpm --filter digital-self-web lint && corepack pnpm build:web",
    "verify:all-local": "node ./scripts/verify-all-local.mjs",
    "simulate:month-decision": "node ./scripts/run-month-decision-simulation.mjs",
    "evaluate:archive-search": "node ./scripts/evaluate-archive-search.mjs",
    "app:install": "node ./scripts/app-runtime.mjs install",
    "app:start": "node ./scripts/app-runtime.mjs start",
    "app:stop": "node ./scripts/app-runtime.mjs stop",
    "app:status": "node ./scripts/app-runtime.mjs status",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f postgres",
    "db:ps": "docker compose ps",
    "db:reset": "docker compose down -v && docker compose up -d postgres",
    "db:migrate": "corepack pnpm --filter @digital-self/api prisma:migrate:dev",
    "db:migrate:deploy": "corepack pnpm --filter @digital-self/api prisma:migrate:deploy",
    "db:migrate:status": "corepack pnpm --filter @digital-self/api prisma:migrate:status",
    "db:generate": "corepack pnpm --filter @digital-self/api prisma:generate"
  },
  "devDependencies": {
    "playwright": "^1.51.1"
  }
}
