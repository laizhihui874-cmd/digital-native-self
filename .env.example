# Shared
NODE_ENV=development
API_HOST=127.0.0.1
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001
CORS_ALLOWED_ORIGINS=http://localhost:3201,http://localhost:3202,http://localhost:3000,http://localhost:3002

# Database
POSTGRES_DB=digital_self
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/digital_self?schema=public
DIRECT_URL=postgresql://postgres:postgres@localhost:5432/digital_self?schema=public
# Verification commands require a separate database whose name contains test/verify/ci.
TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/digital_self_verify?schema=public
DEFAULT_USER_ID=00000000-0000-0000-0000-000000000001
DEFAULT_USER_DISPLAY_NAME=MVP User
DEFAULT_USER_TIMEZONE=Asia/Shanghai

# Local storage
STORAGE_DIR=./storage

# AI provider placeholders
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=
STRUCTURED_REPORT_GENERATOR_PROVIDER=openai-compatible
EXTERNAL_SOURCE_SEARCH_PROVIDER=duckduckgo
AI_PROVIDER_API_KEY=
AI_ASSISTANT_PROVIDER=openai-compatible
